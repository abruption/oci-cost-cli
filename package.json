{
  "name": "oci-cost-cli",
  "version": "0.4.3",
  "description": "Fast, readable OCI cost/usage/outbound-traffic summary across multiple tenancies — no OCI SDK, no Python oci-cli required. Optional Telegram reports + cron scheduling.",
  "type": "module",
  "types": "dist/src/main.d.ts",
  "bin": {
    "oci-cost-cli": "dist/src/main.js",
    "oci-cost": "dist/src/main.js"
  },
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "pretest": "tsc",
    "test": "node --test dist/test/unit.test.js",
    "start": "tsc && node dist/src/main.js",
    "prepack": "tsc"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist/src/**/*.js",
    "dist/src/**/*.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/main.d.ts",
      "default": "./dist/src/main.js"
    },
    "./signer": {
      "types": "./dist/src/signer.d.ts",
      "default": "./dist/src/signer.js"
    }
  },
  "keywords": [
    "oci",
    "oracle-cloud",
    "cost",
    "usage",
    "cli",
    "free-tier",
    "billing"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abruption/oci-cost-cli.git"
  },
  "homepage": "https://github.com/abruption/oci-cost-cli#readme",
  "bugs": {
    "url": "https://github.com/abruption/oci-cost-cli/issues"
  },
  "author": "abruption",
  "dependencies": {
    "@napi-rs/keyring": "^1.3.0"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^18.19.130",
    "eslint": "^9.39.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  }
}
